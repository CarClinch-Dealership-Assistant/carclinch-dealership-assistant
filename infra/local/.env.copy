# Environment file for user-defined variables in docker-compose.yml

# CONFIG_PATH: Path to Config.json file
# Ex: CONFIG_PATH="C:\Users\alice\Documents\GitHub\lead-intake-worker-simulator\config.json"
CONFIG_PATH="./config.json"

# ACCEPT_EULA: Pass 'Y' to accept license terms for SQL Server Linux and Service Bus emulator.
# Service Bus emulator EULA : https://github.com/Azure/azure-service-bus-emulator-installer/blob/main/EMULATOR_EULA.txt
# SQL Server Linux EULA : https://go.microsoft.com/fwlink/?LinkId=746388
ACCEPT_EULA="Y"

# MSSQL_SA_PASSWORD to be filled by user as per policy
MSSQL_SA_PASSWORD="Password123!"

# Port on which emulator will expose Management & Health-check APIs
EMULATOR_HTTP_PORT=5300

# Service Bus connection string for local emulator
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://servicebus-emulator;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;

# Cosmos DB connection string for storing lead details; public emulator endpoint
COSMOS_CONNECTION_STRING=AccountEndpoint=https://cosmosdb-emulator:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==;
COSMOS_ENDPOINT=https://cosmosdb-emulator:8081/
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DB_NAME=CarClinchDB
COSMOS_DB_CONTAINER=messages
COSMOS_VERIFY_SSL=false

# Storage connection string for Azurite emulator
STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true;DevelopmentStorageProxyUri=http://azurite
SB_NAMESPACE=servicebus-emulator

# IPv4 address override for Cosmos DB emulator
AZURE_COSMOS_EMULATOR_IP_ADDRESS_OVERRIDE=192.168.50.39

# Gmail credentials for email processing service to send emails via SMTP
GMAIL_USER="carclinchdev@gmail.com"
GMAIL_APP_PASSWORD=""

# OpenAI API key and base URL for Microsoft Foundry
OPENAI_API_KEY="""
OPENAI_BASE_URL=""
OPENAI_MODEL_NAME="gpt-4.1-mini"
